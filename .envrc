dotenv

export RUST_ENV="${RUST_ENV:-development}"
export RUST_LOG="${RUST_LOG:-info}"

ROOT_DIR="$(pwd)"
IMMUTABLE_BACKEND_CONFIG_FILE="${IMMUTABLE_BACKEND_CONFIG_FILE:-infra/immutable/backend.auto.hcl}"
TESTABLE_BACKEND_CONFIG_FILE="${TESTABLE_BACKEND_CONFIG_FILE:-infra/testable/backend.auto.hcl}"
IMMUTABLE_BACKEND_CONFIG_FILE_ABS="${ROOT_DIR}/${IMMUTABLE_BACKEND_CONFIG_FILE}"
TESTABLE_BACKEND_CONFIG_FILE_ABS="${ROOT_DIR}/${TESTABLE_BACKEND_CONFIG_FILE}"

require_env() {
  local name="$1"
  if [ -z "${!name:-}" ]; then
    echo "Missing required environment variable: ${name}" >&2
    exit 1
  fi
}

for required_var in \
  GCP_PROJECT_ID \
  GCP_PROJECT_NUMBER \
  GCP_REGION \
  GCS_BUCKET \
  GCP_REPOSITORY_ID \
  GCP_WORKLOAD_IDENTITY_POOL \
  GCP_WORKLOAD_IDENTITY_PROVIDER \
  GCP_DEPLOY_SERVICE_ACCOUNT_ID \
  GCP_ADMIN_SERVICE_ACCOUNT_ID \
  GCP_SERVICE_NAME \
  GITHUB_OWNER \
  GITHUB_REPO \
  DOMAIN_NAME \
  DNS_ZONE_NAME \
  GCP_ORGANIZATION_ID \
  ADMIN_USER_EMAIL \
  LOAD_BALANCER_IP \
  MANAGED_SSL_CERTIFICATE_ID \
  LOAD_BALANCER_IP_NAME \
  NETWORK_ENDPOINT_GROUP_NAME \
  BACKEND_SERVICE_NAME \
  URL_MAP_NAME \
  HTTPS_PROXY_NAME \
  HTTPS_FORWARDING_RULE_NAME \
  HTTP_REDIRECT_URL_MAP_NAME \
  HTTP_PROXY_NAME \
  HTTP_FORWARDING_RULE_NAME; do
  require_env "${required_var}"
done

GCP_TF_STATE_PREFIX="${GCP_IMMUTABLE_TF_STATE_PREFIX:-gcp-rust-blog/immutable}" \
  TF_BACKEND_CONFIG_OUTPUT="${IMMUTABLE_BACKEND_CONFIG_FILE_ABS}" \
  "${ROOT_DIR}/scripts/render-backend-config.sh"

GCP_TF_STATE_PREFIX="${GCP_TESTABLE_TF_STATE_PREFIX:-gcp-rust-blog/testable}" \
  TF_BACKEND_CONFIG_OUTPUT="${TESTABLE_BACKEND_CONFIG_FILE_ABS}" \
  "${ROOT_DIR}/scripts/render-backend-config.sh"

export IMMUTABLE_BACKEND_CONFIG_FILE
export TESTABLE_BACKEND_CONFIG_FILE
export DRESS_DEPLOYMENT_ROOT="${ROOT_DIR}/infra/testable"
export DRESS_TERRAFORM_BINARY="${DRESS_TERRAFORM_BINARY:-tofu}"
export TF_VAR_project_id="${GCP_PROJECT_ID}"
export TF_VAR_project_number="${GCP_PROJECT_NUMBER}"
export TF_VAR_region="${GCP_REGION}"
export TF_VAR_repository_id="${GCP_REPOSITORY_ID}"
export TF_VAR_pool_id="${GCP_WORKLOAD_IDENTITY_POOL}"
export TF_VAR_provider_id="${GCP_WORKLOAD_IDENTITY_PROVIDER}"
export TF_VAR_deploy_service_account_id="${GCP_DEPLOY_SERVICE_ACCOUNT_ID}"
export TF_VAR_admin_service_account_id="${GCP_ADMIN_SERVICE_ACCOUNT_ID}"
export TF_VAR_github_owner="${GITHUB_OWNER}"
export TF_VAR_github_repo="${GITHUB_REPO}"
export TF_VAR_service_name="${GCP_SERVICE_NAME}"
export TF_VAR_domain_name="${DOMAIN_NAME}"
export TF_VAR_dns_zone_name="${DNS_ZONE_NAME}"
export TF_VAR_organization_id="${GCP_ORGANIZATION_ID}"
export TF_VAR_admin_user_email="${ADMIN_USER_EMAIL}"
export TF_VAR_load_balancer_ip="${LOAD_BALANCER_IP}"
export TF_VAR_managed_ssl_certificate_id="${MANAGED_SSL_CERTIFICATE_ID}"
export TF_VAR_load_balancer_ip_name="${LOAD_BALANCER_IP_NAME}"
export TF_VAR_network_endpoint_group_name="${NETWORK_ENDPOINT_GROUP_NAME}"
export TF_VAR_backend_service_name="${BACKEND_SERVICE_NAME}"
export TF_VAR_url_map_name="${URL_MAP_NAME}"
export TF_VAR_https_proxy_name="${HTTPS_PROXY_NAME}"
export TF_VAR_https_forwarding_rule_name="${HTTPS_FORWARDING_RULE_NAME}"
export TF_VAR_http_redirect_url_map_name="${HTTP_REDIRECT_URL_MAP_NAME}"
export TF_VAR_http_proxy_name="${HTTP_PROXY_NAME}"
export TF_VAR_http_forwarding_rule_name="${HTTP_FORWARDING_RULE_NAME}"

if command -v gh >/dev/null 2>&1; then
  GITHUB_TOKEN_FROM_GH="$(gh auth token 2>/dev/null || true)"
  if [ -n "${GITHUB_TOKEN_FROM_GH}" ]; then
    export GITHUB_TOKEN="${GITHUB_TOKEN_FROM_GH}"
  fi
fi

if [ -n "${GITHUB_TOKEN:-}" ]; then
  export TF_VAR_github_token="${GITHUB_TOKEN}"
fi
